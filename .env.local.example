# Configuration Email - AsArt'sDev
# Copiez ce fichier en .env.local et remplissez vos vraies valeurs
# ============================================================

# 📧 CONFIGURATION MAILER
# ============================================================

# Option 1: MAIL iCloud
# Utiliser les "mots de passe spécifiques à l'app"
# https://appleid.apple.com → Sécurité → Générer mot de passe
MAILER_DSN=smtp://votre_email@icloud.com:VOTRE_MOT_DE_PASSE_APPSPECIFIQUE@smtp.mail.icloud.com:587?encryption=tls

# Alternative: Gmail
# MAILER_DSN=smtp://your-email@gmail.com:your-app-password@smtp.gmail.com:587?encryption=tls

# Alternative: Mailgun (gratuit pour 5000 emails/mois)
# MAILER_DSN=mailgun+api://key-xxxxx@sandboxXXX.mailgun.org/?region=us

# Adresse FROM (expéditeur)
MAILER_FROM=noreply@asartsdev.com

# Admin email pour notifications critiques
ADMIN_EMAIL=votre_admin@email.com

# Support email
SUPPORT_EMAIL=votre_support@email.com

# Contact & Partenariat email
CONTACT_EMAIL=asartsdev.contact@gmail.com
PARTNERSHIP_EMAIL=asartsdev.contact@gmail.com

# Rapports & Attestations
SEND_REPORTS_ON_DONATION=true
SEND_REPORTS_ON_CONTACT=true
SEND_REPORTS_ON_PARTNERSHIP=true
GENERATE_ATTESTATION=true

# ============================================================
# 🔔 CONFIGURATION DES NOTIFICATIONS
# ============================================================

SEND_DONATION_REMINDERS=true
NOTIFY_ADMIN_ON_DONATION=true
NOTIFY_ADMIN_SUSPICIOUS=true

# ============================================================
# 📊 BASE DE DONNÉES (XAMPP: root sans mot de passe par défaut)
# ============================================================

DATABASE_URL="mysql://root:@127.0.0.1:3306/asartsdev?serverVersion=8.0&charset=utf8mb4"

# ============================================================
# 🔐 SYMFONY
# ============================================================

APP_ENV=dev
APP_SECRET=CHANGEZ_CE_SECRET_32_CHARS_MINIMUM

# ============================================================
# 🏢 INFOS ENTREPRISE
# ============================================================

COMPANY_NAME="AsArt'sDev"
COMPANY_URL="https://asartsdev.com"
COMPANY_PHONE="0781586882"
COMPANY_EMAIL=votre_email@contact.com

# ============================================================
# 🎨 BRANDING
# ============================================================

BRAND_COLOR_PRIMARY="#00f3ff"
BRAND_COLOR_SECONDARY="#0099ff"
