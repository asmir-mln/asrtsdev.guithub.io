# Fichier exemple .env.co
# Valeurs encodees en base64.
# IMPORTANT: copier en .env.co et ne jamais commiter .env.co.

# Mode Stripe: test ou live
STRIPE_MODE=dGVzdA==

# Stripe - identifiants publics/secret
# STRIPE_TEST_PUBLIC_KEY: ID public Stripe (frontend)
# STRIPE_TEST_SECRET_KEY: mot de passe secret Stripe (backend)
# STRIPE_TEST_WEBHOOK_SECRET: secret de signature webhook
STRIPE_TEST_PUBLIC_KEY=cGtfdGVzdF9WT1RSRV9DTEVfUFVCTElRVUVfVEVTVA==
STRIPE_TEST_SECRET_KEY=c2tfdGVzdF9WT1RSRV9DTEVfU0VDUkVURV9URVNU
STRIPE_TEST_WEBHOOK_SECRET=d2hzZWNfVk9UUkVfU0VDUkVUX1RFU1Q=

# Stripe Live
STRIPE_LIVE_PUBLIC_KEY=cGtfbGl2ZV9WT1RSRV9DTEVfUFVCTElRVUVfTElWRQ==
STRIPE_LIVE_SECRET_KEY=c2tfbGl2ZV9WT1RSRV9DTEVfU0VDUkVURV9MSVZF
STRIPE_LIVE_WEBHOOK_SECRET=d2hzZWNfVk9UUkVfU0VDUkVUX0xJVkU=

# PayPal
# PAYPAL_CLIENT_ID: ID client PayPal
# PAYPAL_CLIENT_SECRET: mot de passe secret PayPal
PAYPAL_CLIENT_ID=UEFZUEFMX0NMSUVOVF9JRF9JQ0k=
PAYPAL_CLIENT_SECRET=UEFZUEFMX1NFQ1JFVF9JQ0k=

# Virement/RIB
# BANK_BENEFICIARY: nom beneficiaire
# BANK_IBAN: IBAN complet
# BANK_BIC: code BIC
# BANK_NAME: nom banque
BANK_BENEFICIARY=U2FtaXIgTWlsaWFubmk=
BANK_IBAN=RlI3NiBWT1RSRV9JQkFOX0NPTVBMRVQ=
BANK_BIC=UkVWT0ZSUDI=
