{% extends 'base.html.twig' %}

{% block title %}Dashboard Ministeres - Ultra Top{% endblock %}

{% block body %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/owl.carousel@2.3.4/dist/assets/owl.carousel.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/owl.carousel@2.3.4/dist/assets/owl.theme.default.min.css">

<h1>Dashboard Ministeres - Ultra Top</h1>
<h2>Total profit simule : {{ totalProfit|number_format(0, ',', ' ') }} €</h2>

<section style="margin:20px 0 26px; padding:16px; border-radius:12px; border:1px solid #1e3a8a; background:#0b1220;">
    <h3 style="margin-bottom:12px;">Videos d'ouverture</h3>
    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(260px, 1fr)); gap:12px;">
        <video controls preload="metadata" style="width:100%; border-radius:10px; background:#000;">
            <source src="{{ asset('images/ministere/5110f43cc568447cb1a9fd28253c857b.MOV') }}" type="video/mp4">
            Votre navigateur ne supporte pas la lecture video.
        </video>
        <video controls preload="metadata" style="width:100%; border-radius:10px; background:#000;">
            <source src="{{ asset('images/ministere/5abedd2e94e14258966db3897986533f.MOV') }}" type="video/mp4">
            Votre navigateur ne supporte pas la lecture video.
        </video>
    </div>
</section>

<div class="alert alert-warning p-3" style="padding:12px; border-radius:10px; background:#3f3a12; color:#fff7c2; border:1px solid #6b5f1a; margin:20px 0;">
    <strong>A titre indicatif :</strong> Les prix peuvent varier selon les fluctuations du marche et le cout des matieres premieres. <br>
    Debut operationnel prevu : <strong>2030</strong> <br>
    Objectif : terminer les 4 premiers brevets avant <strong>2036</strong>. <br>
    Tout le materiel et les plans sont prets, il ne reste plus qu'a trouver les financements et monter les appareils.
</div>

<p>Ce projet impacte tous les secteurs cles de l'evolution de l'Union Europeenne : economie, culture, defense, industrie et BTP.</p>

<div class="don-bar-container" style="width: 100%; background-color: #eee; border-radius: 10px; margin:20px 0; overflow:hidden;">
    <div id="don-bar" style="width:0%; height:30px; background-color:#4CAF50; text-align:center; color:white; line-height:30px; border-radius:10px;">
        0%
    </div>
</div>
<p id="don-status">Montant collecte : 0 €</p>

<section class="projet-ultra" style="margin:22px 0; padding:16px; border:1px solid #334155; border-radius:10px; background:#0f1a2e;">
    <h2>Projet strategique EU - Impact multi-sectoriel</h2>
    <p>
        Ce projet touche tous les secteurs de l'evolution europeenne : economie, culture, defense, industrie et BTP.
        Chaque action est pensee pour maximiser l'impact social et economique.
    </p>
    <ul>
        <li>Debut operationnel : 2030</li>
        <li>4 premiers brevets finalises : avant 2036</li>
        <li>Materiel et plans prets - financement a securiser</li>
        <li>Suivi en temps reel de l'importance des dons et de la progression du projet</li>
    </ul>
</section>

<h3>Profits par ministere</h3>
<table class="table table-striped">
    <tr><th>Ministere</th><th>Profit (€)</th></tr>
    {% for p in profits %}
        <tr>
            <td>{{ p.ministere }}</td>
            <td>{{ p.profit|number_format(0, ',', ' ') }}</td>
        </tr>
    {% endfor %}
</table>

<h3>Graphique des profits</h3>
<canvas id="graphProfits" width="400" height="150"></canvas>

<h3 style="margin-top:28px;">Articles ministeriels</h3>
<section style="display:grid; grid-template-columns:repeat(auto-fit, minmax(250px, 1fr)); gap:14px; margin-bottom:18px;">
    <article style="background:#111827; border:1px solid #374151; border-radius:12px; overflow:hidden;">
        <img src="{{ asset('images/ministere/007bba93-af16-4d52-9af2-33ac99ba896e.png') }}" alt="Innovation militaire pour les affaires armees" style="width:100%; height:180px; object-fit:cover;">
        <div style="padding:12px;">
            <h4 style="margin:0 0 6px;">Ministere des Affaires armees</h4>
            <p style="margin:0;">Innovation militaire orientee protection du terrain et efficacite operationnelle.</p>
        </div>
    </article>

    <article style="background:#111827; border:1px solid #374151; border-radius:12px; overflow:hidden;">
        <img src="{{ asset('images/ministere/432b7e00-cbea-41bb-9d34-3123389204c0.png') }}" alt="Innovation medicale pour le ministere de la sante" style="width:100%; height:180px; object-fit:cover;">
        <div style="padding:12px;">
            <h4 style="margin:0 0 6px;">Ministere de la Sante</h4>
            <p style="margin:0;">Innovation medicale pour assistance, diagnostic et suivi des patients.</p>
        </div>
    </article>

    <article style="background:#111827; border:1px solid #374151; border-radius:12px; overflow:hidden;">
        <img src="{{ asset('images/ministere/c3b2f0fd-b8a9-4f78-bc21-35b889f55617.png') }}" alt="Innovation handicap pour le ministere social" style="width:100%; height:180px; object-fit:cover;">
        <div style="padding:12px;">
            <h4 style="margin:0 0 6px;">Ministere du Social</h4>
            <p style="margin:0;">Innovation handicap pour accessibilite, autonomie et inclusion sociale.</p>
        </div>
    </article>
</section>

<h3>Innovations par ministere</h3>
<div id="carouselInnovations" class="owl-carousel owl-theme">
    {% for innovation in innovations %}
        <div class="item card p-3 m-2 shadow" style="background:#111827; border-radius:12px;">
            <h5>{{ innovation.ministere }}</h5>
            <h4>{{ innovation.innovation }}</h4>
            <p>{{ innovation.description }}</p>
            {% set ministereNom = innovation.ministere|lower %}
            {% set imageMinistere = '' %}
            {% if 'arme' in ministereNom or 'defense' in ministereNom %}
                {% set imageMinistere = 'images/ministere/007bba93-af16-4d52-9af2-33ac99ba896e.png' %}
            {% elseif 'sante' in ministereNom or 'medical' in ministereNom %}
                {% set imageMinistere = 'images/ministere/432b7e00-cbea-41bb-9d34-3123389204c0.png' %}
            {% elseif 'social' in ministereNom or 'handicap' in ministereNom %}
                {% set imageMinistere = 'images/ministere/c3b2f0fd-b8a9-4f78-bc21-35b889f55617.png' %}
            {% endif %}

            {% if imageMinistere %}
                <img src="{{ asset(imageMinistere) }}" alt="{{ innovation.innovation }}" class="img-fluid rounded">
            {% elseif innovation.image %}
                <img src="{{ asset('uploads/' ~ innovation.image) }}" alt="{{ innovation.innovation }}" class="img-fluid rounded">
            {% endif %}
            <p><strong>Cout:</strong> {{ innovation.cout }} €</p>
            <p><strong>Marge:</strong> {{ innovation.marge }} €</p>
        </div>
    {% endfor %}
</div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/owl.carousel@2.3.4/dist/owl.carousel.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
$(function() {
    $('.owl-carousel').owlCarousel({
        loop: true,
        margin: 10,
        nav: true,
        responsive: {
            0: { items: 1 },
            600: { items: 2 },
            1000: { items: 3 }
        }
    });

    // Simulation de progression des dons en temps reel
    let objectif = 1000000;
    let collecte = 0;

    function miseAJourDons() {
        let ajout = Math.floor(Math.random() * 5000);
        collecte += ajout;
        if (collecte > objectif) {
            collecte = objectif;
        }

        let pourcentage = Math.floor((collecte / objectif) * 100);
        $('#don-bar').css('width', pourcentage + '%').text(pourcentage + '%');
        $('#don-status').text('Montant collecte : ' + collecte.toLocaleString() + ' €');

        if (collecte < objectif) {
            setTimeout(miseAJourDons, 2000);
        }
    }

    miseAJourDons();

    const ctx = document.getElementById('graphProfits').getContext('2d');
    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: [{% for p in profits %}'{{ p.ministere }}'{% if not loop.last %}, {% endif %}{% endfor %}],
            datasets: [{
                label: 'Profit (€)',
                data: [{% for p in profits %}{{ p.profit }}{% if not loop.last %}, {% endif %}{% endfor %}],
                backgroundColor: '#4CAF50'
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } }
        }
    });
});
</script>
{% endblock %}
