# AsArt'sDev — Configuration Apache / XAMPP
# Fonctionne avec : XAMPP, Apache local, GitHub Pages

Options -Indexes

# Encodage UTF-8
AddDefaultCharset UTF-8

# Page d'accueil par défaut
DirectoryIndex index.html index.php

# Autoriser les fichiers .html, .css, .js, .php, .pdf
<Files ~ "\.(html|css|js|php|pdf|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf)$">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
    <IfModule !mod_authz_core.c>
        Allow from all
    </IfModule>
</Files>

# Protection des fichiers sensibles
<FilesMatch "\.(env|env\.local|json|lock|md|txt|sql|yaml|yml)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Autoriser l'accès aux fichiers nécessaires
<Files "composer.json">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</Files>

# Autoriser package.json à rester inaccessible aussi
<Files "package.json">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</Files>

# CORS pour les requêtes API locales (développement uniquement)
# En production, remplacez "*" par votre domaine exact : https://asartsdev.com
<IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "*"
    Header set Access-Control-Allow-Methods "GET, POST, OPTIONS"
    Header set Access-Control-Allow-Headers "Content-Type"
</IfModule>

# Compression gzip
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript
</IfModule>

# Cache des ressources statiques
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
</IfModule>

# Redirection PHP: donation.php -> donation-form.html (si PHP indisponible)
# Décommentez si besoin :
# RewriteEngine On
# RewriteCond %{REQUEST_FILENAME} !-f
# RewriteRule ^donation\.php$ donation-form.html [R=302,L]
